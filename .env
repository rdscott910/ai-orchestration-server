# OpenClaw Orchestration Server — Environment Configuration
# Copy this file and fill in your values. Never commit the filled version.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to trigger commands
# Find your ID by messaging @userinfobot
TELEGRAM_ALLOWED_USER_IDS=

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Absolute path to the cloud-synced directory for iPad output
# Examples:
#   iCloud: /Users/username/Library/Mobile Documents/com~apple~CloudDocs/OpenClaw
#   OneDrive: /Users/username/Library/CloudStorage/OneDrive-Personal/OpenClaw
SYNC_DIR=

# Path to the Claude Code CLI (install: npm install -g @anthropic-ai/claude-code)
# Leave blank until installed — executor will return a clear error if invoked
CLAUDE_CLI_PATH=

# Path to the Cursor CLI
CURSOR_CLI_PATH=/usr/local/bin/cursor

# Maximum execution time for CLI processes in milliseconds (default: 5 minutes)
EXEC_TIMEOUT_MS=300000

# Log level: debug | info | warn | error
LOG_LEVEL=info
