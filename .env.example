# AI Orchestration Server — Environment Template
# Copy to .env and fill in your values. Never commit the filled .env file.

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_IDS=123456789
ANTHROPIC_API_KEY=sk-ant-...
SYNC_DIR=/absolute/path/to/your/cloud/sync/folder
CLAUDE_CLI_PATH=
CURSOR_CLI_PATH=/usr/local/bin/cursor
EXEC_TIMEOUT_MS=300000
LOG_LEVEL=info
